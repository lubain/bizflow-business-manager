# ─── Neon (production) ────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/bizflow?sslmode=require

# ─── PostgreSQL local (développement) ─────────
# Si DATABASE_URL absent, TypeORM utilise ces variables
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=bizflow
DB_PASSWORD=bizflow_secret
DB_NAME=bizflow

# ─── JWT ──────────────────────────────────────
JWT_SECRET=changez-moi-minimum-32-caracteres-en-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changez-moi-refresh-minimum-32-caracteres
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
